---
const faqs = [
  {
    question: "Für wen ist das Sparring gedacht?",
    answer: [
      "Für Geschäftsführer, Selbstständige und Führungskräfte, die mit KI ernsthaft arbeiten und damit weiterkommen wollen – von der nächsten Entscheidung bis zum täglichen Handgriff.",
      "In unserem Sparring bringst du deine Themen ein, du gehst in die Tiefe, wo du in die Tiefe willst und in die Breite, wo es nötig ist. Hier passt sich das Sparring an dich an, nicht du dich an ein vorgegebenes Format."
    ]
  },
  {
    question: "Wann passt das Sparring nicht?",
    answer: [
      "Wenn du dich nur berieseln lassen willst.",
      "Wenn du einen vorgefertigten Tool-Katalog erwartest.",
      "Wenn du erwartest, dass jemand anderer die Auseinandersetzung mit KI für dich übernimmt."
    ]
  },
  {
    question: "Wozu brauche ich das überhaupt – kann ich mit KI nicht einfach selbst experimentieren?",
    answer: [
      "Selbst auszuprobieren ist der richtige erste Schritt und viele kommen damit auch weit. Was dann kommt, passiert jedoch nicht an einem Wochenende oder nach einem Workshop: das maximale Potenzial herauszuholen, das KI für dich und dein Tagesgeschäft bietet, ist eine Frage von Praxis, Auseinandersetzung und Überblick.",
      "Genau das passiert im Sparring. Dein Thema wird direkt in einen KI-Anwendungsfall übersetzt. Du gewinnst dadurch Zeit, weil du gleich am richtigen Punkt ansetzt."
    ]
  },
  {
    question: "Acht Sessions in zwölf Wochen – was hast du danach, was du jetzt nicht hast?",
    answer: [
      "Vor allem einen praktischen Umgang mit KI in deinem Tagesgeschäft. KI ist fester Bestandteil deiner Arbeitsweise geworden.",
      "Themen, Ideen und Aufgaben, die du bisher als zu mühsam, zu teuer oder zu zeitaufwendig erachtet und daher immer wieder aufgeschoben hast, werden plötzlich machbar.",
      "Du arbeitest eigenständig daran und erschließt dir immer wirkungsvollere, weiterreichende und durchdachtere Anwendungsfälle.",
      "Du kennst dich grundlegend aus, weißt wie du KI für dich einsetzt und kannst in Gesprächen darüber mitreden und einordnen, was du hörst.",
      "Und von hier aus gehst du weiter und nutzt dieses Momentum für dich – mit dem Reiz, noch mehr zu entdecken."
    ]
  },
  {
    question: "Wie steht es um Datenschutz und KI?",
    answer: [
      "Im Sparring arbeitest du in deinen eigenen Tools und mit deinen eigenen Konten – Daten aus deinem Unternehmen bleiben somit in deiner Hand und in deiner Verantwortung.",
      "Man kann KI auch DSGVO-konform nutzen. Wie und welche Tools im Speziellen zu dir passen, ergründen wir gemeinsam."
    ]
  },
  {
    question: "Wie diskret ist das Sparring?",
    answer: [
      "Im 1:1-Sparring bist du mit den Themen, die du einbringst, nicht in einer Gruppe vor anderen und auch nicht in einem Webinar oder Workshop mit etlichen Teilnehmern.",
      "Das macht es möglich, geschäftsinterne Themen, konkrete Beispiele und Detailfragen zu besprechen, die in einem Gruppen-Format weder zeitlich noch inhaltlich Platz hätten.",
      "Was zwischen uns besprochen wird, bleibt zwischen uns."
    ]
  }
];
---

<section id="faq" class="faq-section">
  <div class="faq-container">
    <p class="section-subline">Was dich beschäftigt</p>
    <h2 class="faq-heading">Häufige Fragen</h2>

    <div class="faq-list">
      {faqs.map((faq, index) => (
        <article class="faq-card scroll-reveal" data-reveal-stagger={index}>
          <h3>{faq.question}</h3>
          {faq.answer.map((para) => <p>{para}</p>)}
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    position: relative;
    z-index: 1;
    background-color: var(--black-warm);
    padding: 120px 48px;
    overflow: hidden;
    /* Card-Hüllen-Verstärkung (ADR-035, Schritt 1a + 1b Variante 1.1 final):
       identisch zu Sparring – siehe dort für ausführliche Begründung. */
    --card-bg: rgba(44, 32, 68, 0.95);
  }

  /* Aurora (Farb-Bogen): Lila-Heimkehr, deutlich gedämpfter als Sparring (0.10 statt 0.22) */
  .faq-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse 80% 40% at 50% 0%, rgba(95, 41, 209, 0.10), transparent 60%);
  }

  /* Verlaufstrich am unteren Sektions-Ende als Marken-Geste / Sektions-Trenner.
     Schließt die Sektions-Folge vor dem späteren CTA-Block (Schritt 6) ab. */
  .faq-section::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--section-divider);
    z-index: 3;
    pointer-events: none;
  }

  .faq-container {
    position: relative;
    z-index: 2;
    max-width: 820px;
    margin: 0 auto;
  }

  .faq-heading {
    font-family: 'Inter', sans-serif;
    font-size: 38px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0 0 56px 0;
  }

  /* gap: 40px (statt 16px aus initialem Plan) – mehr Abstand wegen 36px-Halo der Card */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Card-Pattern wie Sparring: Akzent-Streifen oben via ::before-Pseudo.
     Hülle dezent (Border + Halo erben aus globalen Variablen, jetzt neutral). */
  .faq-card {
    --accent: var(--accent-purple);  /* Default, wird per nth-child überschrieben */
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    /* Clippt den ::before-Akzent-Streifen an die Card-Rundung
       (ADR-035, 20.05.2026) – Begründung siehe Sparring.astro. */
    overflow: hidden;
    /* Eigener Stacking-Context für den Inner Glow (ADR-035, Schritt 1b
       24.05.2026) – Begründung siehe Sparring.astro. */
    isolation: isolate;
    padding: 28px 32px;
    backdrop-filter: blur(var(--card-blur));
    -webkit-backdrop-filter: blur(var(--card-blur));
    box-shadow: var(--card-shadow);
    /* Hover-Float (Schritt 5, 17.05.2026): siehe Begründung in
       Sparring.astro. */
    transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
  }

  .faq-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-shadow-hover);
  }

  .faq-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--card-accent-width);
    background: var(--accent);
    /* zusätzlich zum overflow:hidden des Parents, für Robustheit */
    border-top-left-radius: inherit;
    border-top-right-radius: inherit;
  }

  /* Inner Glow (ADR-035, Schritt 1b, 24.05.2026, Variante 1.1 final) –
     Spec identisch zu Sparring, siehe dort für Werte-Begründung
     (Opacity 28 %, Position 50% 20%) und Stacking-Begründung. Wirkt auf
     alle FAQ-Cards einheitlich – nth-child-Rotation des Streifens
     (lila/türkis/magenta) bleibt unberührt, da ::after im Card-Stacking-
     Context unter dem ::before liegt. */
  .faq-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    z-index: -1;
    background: radial-gradient(
      ellipse 75% 55% at 50% 20%,
      color-mix(in srgb, var(--purple-light) 28%, transparent),
      transparent 70%
    );
  }

  /* Drei-Farben-Rotation: purple → teal → magenta → purple → teal → magenta
     Modulo-Pattern, skaliert auch wenn Cards dazukommen oder wegfallen. */
  .faq-card:nth-child(3n+1) { --accent: var(--accent-purple); }
  .faq-card:nth-child(3n+2) { --accent: var(--accent-teal); }
  .faq-card:nth-child(3n)   { --accent: var(--accent-magenta); }

  .faq-card h3 {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    color: var(--white);
    margin: 0 0 16px 0;
  }

  .faq-card p {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-soft);
    margin: 0 0 14px 0;
  }

  .faq-card p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 767px) {
    .faq-section {
      padding: 80px 24px;
    }
    .faq-card {
      padding: 24px 22px;
    }
    .faq-heading {
      font-size: 28px;
      margin-bottom: 40px;
    }
    .faq-list {
      gap: 32px;
    }
  }
</style>
