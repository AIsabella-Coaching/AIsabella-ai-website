---
const faqs = [
  {
    question: "Für wen ist das Sparring gedacht?",
    answer: [
      "Für Geschäftsführer, Selbstständige und Führungskräfte, die mit KI ernsthaft arbeiten und damit weiterkommen wollen – von der nächsten Entscheidung bis zum täglichen Handgriff.",
      "In unserem Sparring bringst du deine Themen ein, du gehst in die Tiefe, wo du in die Tiefe willst und in die Breite, wo es nötig ist. Hier passt sich das Sparring an dich an, nicht du dich an ein vorgegebenes Format."
    ]
  },
  {
    question: "Wann passt das Sparring nicht?",
    answer: [
      "Wenn du dich nur berieseln lassen willst.",
      "Wenn du einen vorgefertigten Tool-Katalog erwartest.",
      "Wenn du erwartest, dass jemand anderer die Auseinandersetzung mit KI für dich übernimmt."
    ]
  },
  {
    question: "Wozu brauche ich das überhaupt – kann ich mit KI nicht einfach selbst experimentieren?",
    answer: [
      "Selbst auszuprobieren ist der richtige erste Schritt und viele kommen damit auch weit. Was dann kommt, passiert jedoch nicht an einem Wochenende oder nach einem Workshop: das maximale Potenzial herauszuholen, das KI für dich und dein Tagesgeschäft bietet, ist eine Frage von Praxis, Auseinandersetzung und Überblick.",
      "Genau das passiert im Sparring. Dein Thema wird direkt in einen KI-Anwendungsfall übersetzt. Du gewinnst dadurch Zeit, weil du gleich am richtigen Punkt ansetzt."
    ]
  },
  {
    question: "Acht Sessions in zwölf Wochen – was hast du danach, was du jetzt nicht hast?",
    answer: [
      "Vor allem einen praktischen Umgang mit KI in deinem Tagesgeschäft. KI ist fester Bestandteil deiner Arbeitsweise geworden.",
      "Themen, Ideen und Aufgaben, die du bisher als zu mühsam, zu teuer oder zu zeitaufwendig erachtet und daher immer wieder aufgeschoben hast, werden plötzlich machbar.",
      "Du arbeitest eigenständig daran und erschließt dir immer wirkungsvollere, weiterreichende und durchdachtere Anwendungsfälle.",
      "Du kennst dich grundlegend aus, weißt wie du KI für dich einsetzt und kannst in Gesprächen darüber mitreden und einordnen, was du hörst.",
      "Und von hier aus gehst du weiter und nutzt dieses Momentum für dich – mit dem Reiz, noch mehr zu entdecken."
    ]
  },
  {
    question: "Wie steht es um Datenschutz und KI?",
    answer: [
      "Im Sparring arbeitest du in deinen eigenen Tools und mit deinen eigenen Konten – Daten aus deinem Unternehmen bleiben somit in deiner Hand und in deiner Verantwortung.",
      "Man kann KI auch DSGVO-konform nutzen. Wie und welche Tools im Speziellen zu dir passen, ergründen wir gemeinsam."
    ]
  },
  {
    question: "Wie diskret ist das Sparring?",
    answer: [
      "Im 1:1-Sparring bist du mit den Themen, die du einbringst, nicht in einer Gruppe vor anderen und auch nicht in einem Webinar oder Workshop mit etlichen Teilnehmern.",
      "Das macht es möglich, geschäftsinterne Themen, konkrete Beispiele und Detailfragen zu besprechen, die in einem Gruppen-Format weder zeitlich noch inhaltlich Platz hätten.",
      "Was zwischen uns besprochen wird, bleibt zwischen uns."
    ]
  }
];
---

<section id="faq" class="faq-section">
  <div class="faq-container">
    <p class="section-subline">Was dich beschäftigt</p>
    <h2 class="faq-heading">Häufige Fragen</h2>

    <div class="faq-list">
      {faqs.map((faq, index) => (
        <article class="faq-card scroll-reveal" data-reveal-stagger={index}>
          <h3 class="faq-question">
            <button
              type="button"
              class="faq-trigger"
              id={`faq-q-${index}`}
              aria-expanded="false"
              aria-controls={`faq-panel-${index}`}
            >
              <span class="faq-question-text">{faq.question}</span>
              <svg class="faq-chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </button>
          </h3>
          <div class="faq-panel" id={`faq-panel-${index}`} role="region" aria-labelledby={`faq-q-${index}`}>
            <div class="faq-panel-inner">
              {faq.answer.map((para) => <p>{para}</p>)}
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-section {
    position: relative;
    z-index: 1;
    background-color: var(--black-warm);
    padding: 120px 48px;
    overflow: hidden;
    /* Card-Hüllen-Verstärkung (ADR-035, Schritt 1a + 1b Variante 1.1 final):
       identisch zu Sparring – siehe dort für ausführliche Begründung. */
    --card-bg: rgba(44, 32, 68, 0.95);
  }

  /* Aurora (Farb-Bogen): Lila-Heimkehr, deutlich gedämpfter als Sparring (0.10 statt 0.22) */
  .faq-section::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    background: radial-gradient(ellipse 80% 40% at 50% 0%, rgba(95, 41, 209, 0.10), transparent 60%);
  }

  /* Verlaufstrich am unteren Sektions-Ende als Marken-Geste / Sektions-Trenner.
     Schließt die Sektions-Folge vor dem späteren CTA-Block (Schritt 6) ab. */
  .faq-section::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: var(--section-divider);
    z-index: 3;
    pointer-events: none;
  }

  .faq-container {
    position: relative;
    z-index: 2;
    max-width: 820px;
    margin: 0 auto;
  }

  .faq-heading {
    font-family: 'Inter', sans-serif;
    font-size: 38px;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.02em;
    color: var(--white);
    margin: 0 0 56px 0;
  }

  /* gap: 40px (statt 16px aus initialem Plan) – mehr Abstand wegen 36px-Halo der Card */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Card-Pattern wie Sparring: Akzent-Streifen oben via ::before-Pseudo.
     Hülle dezent (Border + Halo erben aus globalen Variablen, jetzt neutral). */
  .faq-card {
    --accent: var(--accent-purple);  /* Default, wird per nth-child überschrieben */
    position: relative;
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    /* Clippt den ::before-Akzent-Streifen an die Card-Rundung
       (ADR-035, 20.05.2026) – Begründung siehe Sparring.astro. */
    overflow: hidden;
    /* Eigener Stacking-Context für den Inner Glow (ADR-035, Schritt 1b
       24.05.2026) – Begründung siehe Sparring.astro. */
    isolation: isolate;
    padding: 28px 32px;
    backdrop-filter: blur(var(--card-blur));
    -webkit-backdrop-filter: blur(var(--card-blur));
    box-shadow: var(--card-shadow);
    /* Hover-Float (Schritt 5, 17.05.2026): siehe Begründung in
       Sparring.astro. */
    transition: transform 0.3s ease-out, box-shadow 0.3s ease-out;
  }

  .faq-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--card-shadow-hover);
  }

  .faq-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: var(--card-accent-width);
    background: var(--accent);
    /* zusätzlich zum overflow:hidden des Parents, für Robustheit */
    border-top-left-radius: inherit;
    border-top-right-radius: inherit;
  }

  /* Inner Glow (ADR-035, Schritt 1b, 24.05.2026, Variante 1.1 final) –
     Spec identisch zu Sparring, siehe dort für Werte-Begründung
     (Opacity 28 %, Position 50% 20%) und Stacking-Begründung. Wirkt auf
     alle FAQ-Cards einheitlich – nth-child-Rotation des Streifens
     (lila/türkis/magenta) bleibt unberührt, da ::after im Card-Stacking-
     Context unter dem ::before liegt. */
  .faq-card::after {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: inherit;
    z-index: -1;
    background: radial-gradient(
      ellipse 75% 55% at 50% 20%,
      color-mix(in srgb, var(--purple-light) 28%, transparent),
      transparent 70%
    );
  }

  /* Drei-Farben-Rotation: purple → teal → magenta → purple → teal → magenta
     Modulo-Pattern, skaliert auch wenn Cards dazukommen oder wegfallen.
     --accent     = Linien-/Streifenfarbe (Volltonfarbe, ::before) – unverändert.
     --accent-text = heller Hover-/Open-State-Text. Eigene helle Töne, weil die
       dunklen Linienfarben (Violett #5F29D1 = 1,98:1, Magenta #A62AEB = 3,01:1)
       auf dem dunklen Card-BG #2B1F42 WCAG AA (4,5:1) reißen (ADR-040 Addendum).
       Werte: Violett #B07CFF = 5,21:1, Türkis #00CFC4 = 7,78:1, Magenta
       #D46BF5 = 5,24:1 – alle AA-konform. */
  .faq-card:nth-child(3n+1) { --accent: var(--accent-purple);  --accent-text: #B07CFF; }
  .faq-card:nth-child(3n+2) { --accent: var(--accent-teal);    --accent-text: var(--teal); }
  .faq-card:nth-child(3n)   { --accent: var(--accent-magenta); --accent-text: #D46BF5; }

  /* Frage-Zeile als barrierefreier Button (gesamte Zeile klickbar).
     Button visuell unsichtbar – Typografie bleibt identisch zur alten h3
     (17px/600), kein Hintergrund, kein Border. */
  .faq-question {
    margin: 0;
  }

  .faq-trigger {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    width: 100%;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    color: var(--white);
    transition: color 0.3s ease-out;
    /* System-Tap-Flash unterdrücken, damit der eigene Open-State (unten)
       beim Antippen auf Touch sauber sichtbar ist und nicht überlagert wird. */
    -webkit-tap-highlight-color: transparent;
  }

  .faq-question-text {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 600;
    line-height: 1.4;
    color: inherit;
  }

  /* Open-State (Desktop + Mobile identisch): solange die Frage offen ist
     (aria-expanded="true"), bleibt der Fragetext in der hellen Akzentfarbe.
     Dominiert automatisch, wenn die Maus weggeht – gleicher Farbwert. */
  .faq-trigger[aria-expanded="true"] {
    color: var(--accent-text);
  }

  /* Hover NUR auf Geräten mit echtem Hover (Desktop) – verhindert
     Sticky-Hover beim Tap auf Touch-Geräten. */
  @media (hover: hover) {
    .faq-trigger:hover {
      color: var(--accent-text);
    }
  }

  /* Tastatur-Fokus: heller Akzent + sichtbarer Fokusring, geräteunabhängig
     (außerhalb der hover-Query). */
  .faq-trigger:focus-visible {
    color: var(--accent-text);
    outline: 2px solid var(--accent-text);
    outline-offset: 4px;
    border-radius: 4px;
  }

  /* Feines Linien-Chevron (currentColor → folgt dem Trigger-Farbwechsel).
     Rotation beim Öffnen via CSS-Transition (power3-nahe cubic-bezier,
     gleiche Dauer wie die GSAP-Höhenanimation). */
  .faq-chevron {
    flex-shrink: 0;
    color: var(--text-soft);
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.3s ease-out;
  }

  .faq-trigger[aria-expanded="true"] .faq-chevron {
    transform: rotate(180deg);
  }

  /* Antwort-Panel: standardmäßig geschlossen (height 0). Höhe wird per
     GSAP animiert (height: auto ↔ 0). overflow:hidden klemmt den Inhalt.
     Antworttexte bleiben IMMER im DOM (a11y / Screen-Reader). */
  .faq-panel {
    height: 0;
    overflow: hidden;
  }

  /* Abstand Frage→Antwort nur im offenen Zustand (war früher h3 margin). */
  .faq-panel-inner {
    padding-top: 16px;
  }

  .faq-card p {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-soft);
    margin: 0 0 14px 0;
  }

  .faq-card p:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 767px) {
    .faq-section {
      padding: 80px 24px;
    }
    .faq-card {
      padding: 24px 22px;
    }
    .faq-heading {
      font-size: 28px;
      margin-bottom: 40px;
    }
    .faq-list {
      gap: 32px;
    }
  }

  /* Reduced-motion: keine Chevron-Rotation/Farb-Transition; das Öffnen/
     Schließen setzt die Höhe im Script ohne GSAP-Tween sofort. */
  @media (prefers-reduced-motion: reduce) {
    .faq-trigger,
    .faq-chevron {
      transition: none;
    }
  }
</style>

<script is:inline>
  /* FAQ-Accordion (ADR-040): Multi-Open, Default alle geschlossen.
     Höhenanimation via GSAP (height: auto ↔ 0, ease power3.out) – konsistent
     mit Magnetic-Button. Antworttexte bleiben im DOM, nur die Höhe wird
     gesteuert. GSAP wird via defer geladen → Logik läuft in DOMContentLoaded,
     dann ist `gsap` garantiert verfügbar. Fallback ohne GSAP / bei
     reduced-motion: Höhe wird sofort gesetzt. */
  (function () {
    function initFaqAccordion() {
      var triggers = document.querySelectorAll('.faq-trigger');
      if (!triggers.length) return;

      var prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      var hasGSAP = typeof gsap !== 'undefined';
      var DURATION = 0.35;

      Array.prototype.forEach.call(triggers, function (trigger) {
        var panel = document.getElementById(trigger.getAttribute('aria-controls'));
        if (!panel) return;

        trigger.addEventListener('click', function () {
          var isOpen = trigger.getAttribute('aria-expanded') === 'true';
          trigger.setAttribute('aria-expanded', isOpen ? 'false' : 'true');

          if (prefersReduced || !hasGSAP) {
            panel.style.height = isOpen ? '0px' : 'auto';
            return;
          }

          gsap.to(panel, {
            height: isOpen ? 0 : 'auto',
            duration: DURATION,
            ease: 'power3.out',
            overwrite: true
          });
        });
      });
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFaqAccordion);
    } else {
      initFaqAccordion();
    }
  })();
</script>
