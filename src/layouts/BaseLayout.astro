import '../styles/global.css';
import { calendlyUrl } from '../config/site';

interface Props {
  title: string;
  description?: string;
  robots?: string;
  canonical?: string;
  legalPage?: boolean;
}

const {
  title,
  description,
  robots = "index, follow",
  canonical = "https://aisabella.ai",
  legalPage = false,
} = Astro.props;

// Header-Menü-Items zentral definiert (DRY): Desktop- und Mobile-Nav beziehen
// sich beide hierauf. Auf Legal-/404-Seiten (legalPage) zeigen die Anchors als
// Cross-Page-Links auf die Hauptseiten-Sections (/#id) statt auf In-Page-Anchors
// (#id), die dort nicht existieren. Auf der Hauptseite bleibt es #id (In-Page-Scroll).
const navItems = [
  { id: 'sparring', label: 'Sparring' },
  { id: 'beraterstab', label: 'Beraterstab' },
  { id: 'ueber-mich', label: 'Über Mich' },
  { id: 'testimonials', label: 'Stimmen' },
  { id: 'faq', label: 'FAQ' },
];
const navHref = (id: string) => (legalPage ? `/#${id}` : `#${id}`);
