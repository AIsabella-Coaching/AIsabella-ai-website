---
import BaseLayout from '../layouts/BaseLayout.astro';
import { calendlyUrl } from '../config/site';
---
<BaseLayout
  title="404 - Seite nicht gefunden | AIsabella"
  description="Lerne, KI zu denken. Dein 1:1 KI-Sparring für Unternehmer:innen & Führungskräfte in Wien. Entwickle die strategische Denkweise für deinen entscheidenden Vorsprung."
  robots="noindex, follow"
  legalPage
>
  <main>
    <section
      id="error-section"
      class="relative flex flex-col items-center justify-center overflow-hidden px-6 text-center"
      style="z-index: 3;"
    >
      <!-- Ambient Glow Orbs -->
      <div
        class="absolute -top-32 -left-32 w-96 h-96 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(138, 63, 252, 0.22) 0%, transparent 70%); filter: blur(72px);"
        aria-hidden="true"
      ></div>
      <div
        class="absolute -bottom-32 -right-32 w-96 h-96 rounded-full pointer-events-none"
        style="background: radial-gradient(circle, rgba(8, 211, 187, 0.18) 0%, transparent 70%); filter: blur(88px);"
        aria-hidden="true"
      ></div>

      <!-- Status-Readout -->
      <p class="status-line mb-4" aria-hidden="true">
        SYS_ERR &nbsp;■&nbsp; NODE://aisabella.ai/&lt;unknown&gt; &nbsp;■&nbsp; STATUS: 404<span class="caret">_</span>
      </p>

      <!-- Glitch-404 -->
      <div class="glitch-404" data-text="404" aria-hidden="true">404</div>

      <!-- Scramble H1 -->
      <h1
        id="err-heading"
        class="text-xl md:text-2xl font-bold tracking-widest text-white mt-4 mb-6 uppercase"
        style="letter-spacing: 0.22em;"
      >
        Seite nicht gefunden
      </h1>

      <!-- Subtext -->
      <p class="text-gray-400 max-w-md mx-auto mb-10 text-base leading-relaxed">
        Diese Seite existiert nicht – aber dein nächster<br class="hidden md:block">
        strategischer KI-Impuls wartet bereits.
      </p>

      <!-- Primary CTA -->
      <a
        href="/"
        class="cta-button text-white font-bold py-4 px-10 rounded-lg text-lg"
        aria-label="Zurück zur Startseite"
      >
        Zurück zur Startseite
      </a>

      <!-- Secondary Calendly-Link — gleiche Schriftgröße wie Subtext (16 px / 26 px), gleicher Farbton (gray-400). mb-8 erzeugt ~32 px Luft zum Footer-Beginn. -->
      <p class="text-base text-gray-400 leading-relaxed mt-6 mb-8">
        Oder starte direkt mit einem
        <a
          href={calendlyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="gradient-text font-semibold hover:opacity-80 transition"
        >kostenfreien Gespräch</a>.
      </p>
    </section>
  </main>

  <style>
    /* === GLITCH 404 === */
    .glitch-404 {
      position: relative;
      font-size: clamp(7rem, 22vw, 18rem);
      font-weight: 900;
      line-height: 1;
      letter-spacing: -0.04em;
      background: linear-gradient(90deg, #08D3BB 0%, #33B1FF 50%, #8A3FFC 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
      user-select: none;
    }
    .glitch-404::before,
    .glitch-404::after {
      content: attr(data-text);
      position: absolute;
      inset: 0;
      background: linear-gradient(90deg, #08D3BB 0%, #33B1FF 50%, #8A3FFC 100%);
      -webkit-background-clip: text;
      background-clip: text;
      color: transparent;
    }
    .glitch-404::before {
      animation: g404top 4s infinite;
      clip-path: polygon(0 0, 100% 0, 100% 38%, 0 38%);
    }
    .glitch-404::after {
      animation: g404bot 4s infinite;
      clip-path: polygon(0 65%, 100% 65%, 100% 100%, 0 100%);
    }
    @keyframes g404top {
      0%, 80%, 100% { transform: translate(0); filter: none; }
      81% { transform: translate(-4px, 1px); filter: hue-rotate(80deg) brightness(1.4); }
      83% { transform: translate(4px, -1px); filter: hue-rotate(-80deg) brightness(0.9); }
      85% { transform: translate(-2px, 2px); filter: hue-rotate(40deg); }
      87% { transform: translate(2px, -2px); filter: none; }
      89% { transform: translate(0); }
    }
    @keyframes g404bot {
      0%, 77%, 100% { transform: translate(0); filter: none; }
      78% { transform: translate(5px, -1px); filter: hue-rotate(-80deg) brightness(1.3); }
      80% { transform: translate(-5px, 1px); filter: hue-rotate(80deg); }
      82% { transform: translate(3px, 2px); filter: none; }
      84% { transform: translate(-2px, -1px); }
      86% { transform: translate(0); }
    }
    @media (prefers-reduced-motion: reduce) {
      .glitch-404::before,
      .glitch-404::after { animation: none !important; }
    }

    /* === STATUS-LINE === */
    .status-line {
      font-family: 'Courier New', monospace;
      font-size: 0.78rem;
      letter-spacing: 0.18em;
      color: rgba(8, 211, 187, 0.65);
    }
    .caret {
      animation: blink 1s step-end infinite;
    }
    @keyframes blink {
      0%, 100% { opacity: 1; }
      50% { opacity: 0; }
    }
    @media (prefers-reduced-motion: reduce) {
      .caret { animation: none; }
    }
  </style>

  <script is:inline>
    /* Auf window 'load' warten statt 'DOMContentLoaded' — ai-design-system.js
       wird im BaseLayout mit `defer` geladen, ist erst zum load-Event garantiert
       initialisiert. Master 404.html hatte keine defer-Scripts; dort reichte
       DOMContentLoaded. Im Astro-BaseLayout-Setup ist load der stabile Marker. */
    window.addEventListener('load', function () {
      if (window.AIsabellaDS && window.AIsabellaDS.initTextScramble) {
        window.AIsabellaDS.initTextScramble(['#err-heading', '.glitch-404']);
      }
    });
  </script>
</BaseLayout>
